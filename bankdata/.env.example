APP_NAME="Bank Data - Kantor Gubernur"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Makassar
APP_URL=https://bankdata-namakalian.great-site.net
APP_LOCALE=id

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bankdata
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=30
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

CACHE_STORE=database
QUEUE_CONNECTION=database

# --- Keamanan Login & 2FA ---
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=5
GOOGLE2FA_ENABLED=true

# --- Upload dokumen ---
UPLOAD_MAX_SIZE_KB=5120
UPLOAD_ALLOWED_MIMES=pdf,jpg,jpeg,png,xlsx,docx

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="[email protected]"
MAIL_FROM_NAME="${APP_NAME}"
