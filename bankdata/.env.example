APP_NAME="Bank Data - Kantor Gubernur"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Makassar
APP_URL=https://your-project.vercel.app
APP_LOCALE=id

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=6543
DB_DATABASE=postgres
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=cookie
SESSION_LIFETIME=30
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=array
QUEUE_CONNECTION=sync

# --- Keamanan Login & 2FA ---
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=5
GOOGLE2FA_ENABLED=true

# --- Upload dokumen ---
UPLOAD_MAX_SIZE_KB=5120
UPLOAD_ALLOWED_MIMES=pdf,jpg,jpeg,png,xlsx,docx

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="[email protected]"
MAIL_FROM_NAME="${APP_NAME}"

# Supabase Storage / S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=bankdata-storage
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=true
